{
  "installCommand": "npm install",
  "buildCommand":   "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "BE/api/*.js": {}
  },
  "rewrites": [
    { "source": "/api/:path*",      "destination": "/BE/api/:path*" },
    { "source": "/((?!BE/api/).*)", "destination": "/index.html"    }
  ]
}
